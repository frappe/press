[Unit]
Description=Live Syncing (Mirror) Daemon for Database to On-Prem Server
After=network.target

[Service]
Restart=on-failure
RestartSec=5
Type=simple
User=root
Group=root
ExecStart=/usr/bin/lsyncd -nodaemon /etc/on-prem-lsyncd-db/lsyncd.conf.lua
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
