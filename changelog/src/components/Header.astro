---
import Logo from "./Logo.astro";
const baseurl = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur">
  <div class="border-b border-surface-gray-2 bg-red">
    <nav class="max-w-page flex mx-auto p-3 md:px-0 md:py-4 gap-3 items-center">
      <a class="flex items-center gap-2" href={`${baseurl}/`}>
        <div class="size-4 md:size-6"><Logo /></div>
        Frappe Cloud
      </a>
    </nav>
  </div>
</header>
